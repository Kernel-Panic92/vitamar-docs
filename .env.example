# ─── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vitamar_docs
DB_USER=postgres
DB_PASSWORD=tu_password

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=8h

# ─── Servidor ─────────────────────────────────────────────────
PORT=3100
NODE_ENV=development

# ─── FortiMail / IMAP ─────────────────────────────────────────
IMAP_HOST=mail.tudominio.com
IMAP_PORT=993
IMAP_USER=facturas@vitamar.com
IMAP_PASSWORD=password_correo
IMAP_TLS=true
IMAP_FOLDER=INBOX
IMAP_POLL_MINUTES=5

# ─── Correo saliente (notificaciones) ─────────────────────────
SMTP_HOST=mail.tudominio.com
SMTP_PORT=587
SMTP_USER=notificaciones@vitamar.com
SMTP_PASSWORD=password_smtp
SMTP_FROM=Vitamar Docs <notificaciones@vitamar.com>

# ─── Archivos ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads/facturas
MAX_FILE_MB=10
