# ─── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vitamar_docs
DB_USER=postgres
DB_PASSWORD=tu_password

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=8h

# ─── Servidor ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3100
NODE_ENV=production

# ─── FortiMail / IMAP (configurado desde la GUI) ──────────────
# Estas variables se usan como fallback. La configuración principal
# se gestiona desde la interfaz en Configuración → IMAP.
IMAP_HOST=mail.tudominio.com
IMAP_PORT=993
IMAP_USER=facturas@tudominio.com
IMAP_PASSWORD=password
IMAP_TLS=true
IMAP_FOLDER=INBOX
IMAP_POLL_MINUTES=5

# ─── Correo saliente (notificaciones) ─────────────────────────
SMTP_HOST=mail.tudominio.com
SMTP_PORT=587
SMTP_USER=notificaciones@tudominio.com
SMTP_PASSWORD=password
SMTP_FROM=Vitamar Docs <notificaciones@tudominio.com>

# ─── App URL (para enlaces en correos) ─────────────────────────
APP_URL=http://localhost:3100

# ─── Archivos ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_MB=10
